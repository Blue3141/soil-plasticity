/*
 * Test: capsula che cade su piano lunare — nodo singolo
 *
 * Una massa di 500 kg scende a 3 m/s. Il piano è z=0, normale (0,0,1).
 * Il nodo parte da z=0.5 m, quindi entra in contatto dopo ~0.17 s.
 *
 * Smorzamento Bekker (k_p=0.5): E_diss = k_p/2 * A*KBek*z_max^2
 * Contributo idrodinamico: FNH = h*ANOR*VN^2*tanh(VN/VN0)
 *   h = 0.5*1700*1.2 = 1020 kg/m^3  (rho=1700, Cd=1.2 piastra piana)
 *   ANOR = pi * 0.1^2 = 0.0314 m^2  (pad circolare r=0.1 m)
 *   VN0  = 0.3 m/s  (10% di VN_max = 3 m/s)
 *
 * Usage:
 *   mbdyn -f lunar_landing.mbd -o out/lunar_landing
 */

begin: data;
    problem: initial value;
end: data;

begin: initial value;
    initial time: 0.;
    final time: 5.;
    time step: 1.e-3;
    max iterations: 30;
    tolerance: 1.e-6;
    method: ms, 0.6;
end: initial value;

begin: control data;
    structural nodes: 1;
    rigid bodies: 1;
    loadable elements: 1;
    gravity;
    default output: structural, accelerations, loadable;
end: control data;

module load: "libmodule-soil-plasticity";

begin: nodes;
    structural: 1,
        dynamic,
        0., 0., 0.5,
        eye,
        0., 0., -3.,
        null;
end: nodes;

begin: elements;
    gravity: uniform, 0., 0., -1., 1.62;

    body: 1,
        1,
        500.,
        null,
        eye;

    user defined: 1, surface impact,
        plane normal, 0., 0., 1.,
        plane point,  0., 0., 0.,
        /* Bekker-Wong (obbligatorio): regolite lunare sciolta */
        kc,            1400.,
        kphi,          820000.,
        n,             1.0,
        pad radius,    0.10,
        plastic ratio, 0.5,
        hydrodynamic,
            h,    1020.,
            VN0,  0.3,
            ZN0,  0.02,
        friction, 0.4,
        nodes, 1,
            1;
end: elements;
